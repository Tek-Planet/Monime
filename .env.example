# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted (e.g. https://ais-dev-...).
# Used for self-referential links, OAuth callbacks, and API redirects.
APP_URL=

# MONIME_API_KEY: Secret key provided by Monime dashboard (https://dashboard.monime.io)
MONIME_API_KEY=

# MONIME_SPACE_ID: Your Monime Space ID (retrieved from your Monime space settings or dashboard)
MONIME_SPACE_ID=
